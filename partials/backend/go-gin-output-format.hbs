    Router: {module}/router/router.go 或 main.go
    Handler: {module}/handler/{resource}_handler.go 或 {module}/controller/{resource}_controller.go
    Service: {module}/service/{resource}_service.go
    Repository: {module}/repository/{resource}_repository.go 或 {module}/dao/{resource}_dao.go
    Model: {module}/model/{resource}.go
    DTO/Request: {module}/dto/{resource}_dto.go 或 {module}/request/{resource}_request.go
    Response: {module}/response/{resource}_response.go（如有）