    Route: routes/{resource}.js 或 src/routes/{resource}.routes.js
    Controller: controllers/{resource}.controller.js 或 src/controllers/{resource}.controller.js
    Service: services/{resource}.service.js 或 src/services/{resource}.service.js
    Model: models/{resource}.model.js 或 src/models/{resource}.model.js
    Middleware: middleware/auth.js, middleware/validate.js（如有）
    Validator: validators/{resource}.validator.js（如有）